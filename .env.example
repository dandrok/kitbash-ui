# Copy to .env and fill in real values. Never commit .env.
#   cp .env.example .env
#
# Path A (local agent): load these on your machine.
# Path B (GitHub Actions): add the SAME names under
#   Repo → Settings → Secrets and variables → Actions
# .env is NOT uploaded to Actions automatically.
#
# Full guide: docs/security-and-secrets.md

# --- GitHub (required for gh PR / issue automation) ---
# Fine-grained PAT: https://github.com/settings/personal-access-tokens/new
# Repo: kitbash-ui only. Permissions: Contents (RW), Pull requests (RW),
# Issues (RW), Metadata (R). Add Workflows (RW) only if editing CI files.
# Prefer: gh auth login  (then you may leave this empty)
GH_TOKEN=

# Optional alias some tools expect
# GITHUB_TOKEN=

# --- AI provider (only if a headless/local agent calls the API) ---
# xAI: https://console.x.ai/
# XAI_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# --- Optional later ---
# NPM_TOKEN=
