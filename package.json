{
  "name": "@ktbsh/ui",
  "version": "0.1.0",
  "description": "Framework-agnostic design system components built with @ktbsh/sdk (vanilla CE + React wrappers).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dandrok/kitbash-ui.git"
  },
  "homepage": "https://github.com/dandrok/kitbash-ui#readme",
  "bugs": {
    "url": "https://github.com/dandrok/kitbash-ui/issues"
  },
  "keywords": [
    "kitbash",
    "design-system",
    "web-components",
    "custom-elements",
    "react",
    "typescript"
  ],
  "scripts": {
    "tokens:build": "bun run scripts/tokens.ts build",
    "tokens:check": "bun run scripts/tokens.ts check",
    "build": "bun run tokens:check && kitbash build",
    "dev": "kitbash dev",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "ci": "biome ci .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "verify": "bun run tokens:check && bun run ci && bun run typecheck && bun run test && bun run build && bun run build-storybook"
  },
  "dependencies": {
    "@ktbsh/sdk": "0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-docs": "10.5.2",
    "@storybook/web-components-vite": "10.5.2",
    "@types/bun": "1.3.9",
    "lit": "3.3.1",
    "storybook": "10.5.2",
    "typescript": "5.9.3",
    "vite": "6.3.5"
  }
}
