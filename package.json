{
  "name": "@ktbsh/ui",
  "version": "0.1.0",
  "description": "Framework-agnostic design system components built with @ktbsh/sdk (vanilla CE + React wrappers).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dandrok/kitbash-ui.git"
  },
  "homepage": "https://github.com/dandrok/kitbash-ui#readme",
  "bugs": {
    "url": "https://github.com/dandrok/kitbash-ui/issues"
  },
  "keywords": [
    "kitbash",
    "design-system",
    "web-components",
    "custom-elements",
    "react",
    "typescript"
  ],
  "scripts": {
    "build": "kitbash build",
    "dev": "kitbash dev",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "ci": "biome ci .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "verify": "bun run ci && bun run typecheck && bun run build"
  },
  "dependencies": {
    "@ktbsh/sdk": "0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "1.3.9",
    "typescript": "5.9.3"
  }
}
